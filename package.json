{
  "name": "foodiemap-tests",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "test:syntax": "node --check app.js && node --check location-core.mjs && python3 -m py_compile server.py scripts/migrate_sqlite_to_postgres_gcs.py",
    "test:unit": "node --test tests/location-core.test.mjs && npm run test:syntax",
    "test:e2e": "playwright test --project=desktop",
    "test:e2e:mobile": "playwright test --project=mobile",
    "test:e2e:ui": "playwright test --ui",
    "test:staging": "E2E_TARGET=staging playwright test --project=staging",
    "test:all": "npm run test:unit && playwright test --project=desktop --project=mobile"
  },
  "devDependencies": {
    "@playwright/test": "1.61.1"
  }
}
